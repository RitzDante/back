@model ActiveCitizen.Web.Models.ClaimViewModel
@using ActiveCitizen.Web.Models

@{
    ViewData["Title"] = $"Заявка #{Model.Id}";
    var statuses = ViewBag.Statuses as List<StatusViewModel> ?? new List<StatusViewModel>();
}

<h2>Заявка #@Model.Id</h2>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success mt-3">@TempData["SuccessMessage"]</div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger mt-3">@TempData["ErrorMessage"]</div>
}

<div class="mt-4">
    <dl class="row">
        <dt class="col-sm-3">Тип нарушения</dt>
        <dd class="col-sm-9">@Model.ViolationTypeName</dd>

        <dt class="col-sm-3">Описание</dt>
        <dd class="col-sm-9">
            @if (string.IsNullOrWhiteSpace(Model.Description))
            {
                <span class="text-muted">Описание не указано</span>
            }
            else
            {
                @Model.Description
            }
        </dd>

        <dt class="col-sm-3">Адрес</dt>
        <dd class="col-sm-9">@Model.Address</dd>

        <dt class="col-sm-3">Координаты</dt>
        <dd class="col-sm-9">(@Model.Latitude, @Model.Longitude)</dd>

        <dt class="col-sm-3">Статус</dt>
        <dd class="col-sm-9">@Model.StatusName</dd>

        <dt class="col-sm-3">Дата создания</dt>
        <dd class="col-sm-9">@Model.CreatedAt.ToString("dd.MM.yyyy HH:mm")</dd>
    </dl>
</div>

<div class="mt-4">
    <h4>Фотография нарушения</h4>

    @if (Model.HasPhoto)
    {
        <div style="max-width: 700px;">
            <img src="@Url.Action("Photo", "Inspector", new { id = Model.Id })"
                 alt="Фото нарушения"
                 class="img-fluid rounded border"
                 style="max-height: 500px; object-fit: contain;" />
        </div>
    }
    else
    {
        <p class="text-muted">Фото не прикреплено.</p>
    }
</div>

<div class="mt-4">
    <h4>Изменить статус</h4>

    <form asp-action="ChangeStatus" method="post" class="d-flex align-items-center gap-2">
        @Html.AntiForgeryToken()

        <input type="hidden" name="id" value="@Model.Id" />

        <select name="newStatusId" class="form-control" style="width: 260px;">
            @foreach (var status in statuses)
            {
                if (status.Id == Model.StatusId)
                {
                    <option value="@status.Id" selected>@status.Name</option>
                }
                else
                {
                    <option value="@status.Id">@status.Name</option>
                }
            }
        </select>

        <button type="submit" class="btn btn-primary">Сохранить</button>
    </form>
</div>

<div class="mt-4">
    <a asp-action="Index">Вернуться назад</a>
</div>