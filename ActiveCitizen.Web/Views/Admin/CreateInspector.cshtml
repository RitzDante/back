@{
	ViewContext.ClientValidationEnabled = false;
}

@model CreateInspectorViewModel
@{
	ViewData["Title"] = "Добавление инспектора";
}

<h2>Добавление нового инспектора</h2>

<div class="row">
	<div class="col-md-6">
		<form asp-action="CreateInspector" method="post">
			<div asp-validation-summary="ModelOnly" class="text-danger"></div>
		
			<div class="form-group mb-3">
				<label asp-for="FullName"></label>
				<input asp-for="FullName"/>
				<span asp-validation-for="FullName" class="text-danger"></span>
			</div>

			<div class="form-group mb-3">
				<label asp-for="Email"></label>
				<input asp-for="Email" />
				<span asp-validation-for="Email" class="text-danger"></span>
			</div>

			<div class="form-group mb-3">
				<label asp-for="Password"></label>
				<input asp-for="Password" type="password"/>
				<span asp-validation-for="Password" class="text-danger"></span>
			</div>

			<div class="form-group mb-3">
				<label asp-for="DistrictId" class="form-label"></label>
				<select asp-for="DistrictId" class="form-control" asp-items="@(new SelectList(ViewBag.Districts, "Id", "Name"))">
				<option value="">-- Выберите район --</option>
				</select>
				<span asp-validation-for="DistrictId" class="text-danger"></span>
			</div>

			<button type="submit" class="btn btn-primary">Создать</button>
			<a asp-action="Index" class="btn btn-secondary">Отмена</a>
		</form>
	</div>
</div>

@section Scripts{
	<partial name="_ValidationScriptsPartial" />
}
