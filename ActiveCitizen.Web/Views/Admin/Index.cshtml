@model List<ActiveCitizen.Web.Models.InspectorViewModel>
@{
    ViewData["Title"] = "Панель администратора";
}

	<h1>Управление сотрудниками</h1>
    <div class="row mt-4">
        <div class="col-md-12">
            <div class="card">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                    <a asp-action="CreateInspector" class="btn btn-primary">Добавить инспектора</a>
                    <div class="w-50">
                        <input type="text" id="searchInput" class="form-control" placeholder="Поиск..." />
                    </div>
                </div>
                <h2 class="mt-5">Список инспекторов</h2>

                @if (Model != null && Model.Any())
                {
                <div class="table-responsive">
                    <table id="inspectorsTable" class="table table-striped">
                        <thead>
                            <tr>
                                <th>ФИО</th>
                                <th>Почта</th>
                                <th>Район</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var inspector in Model)
                            {
                              <tr>
                                <td>@inspector.FullName</td>
                                <td>@inspector.Email</td>
                                <td>@inspector.DistrictName</td>
                                <td><a asp-action="EditInspector" asp-route-id="@inspector.Id" class="btn btn-sm btn-outline-primary">Редактировать</a></td>
                              </tr>
                            }
                        </tbody>
                    </table>
                </div>
                }
                else
                {
                    <p>Инспекторы пока не добавлены</p>
                }
                </div>
            </div>
        </div>
    </div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success mt-3"> @TempData["SuccessMessage"]</div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-success mt-3"> @TempData["ErrorMessage"]</div>
}

@section Scripts {
    <script>
        document.getElementById('searchInput').addEventListener('keyup', function(){
            var filter = this.value.toLowerCase();
            var rows = document.querySelectorAll('#inspectorsTable tbody tr');
            rows.forEach(function(row){
                var fullName = row.cells[0].textContent.toLowerCase();
                var email = row.cells[1].textContent.toLowerCase();
                var district = row.cells[2].textContent.toLowerCase();

                if (fullName.includes(filter) || email.includes(filter) || district.includes(filter)){
                    row.style.display = '';
                } else {
                    row.style.display = 'none';
                }
            });
        });
    </script>
}